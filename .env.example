# Azure OpenAI model deployed in your Foundry project.
AZURE_AI_MODEL_DEPLOYMENT_NAME=gpt-4o

# Azure OpenAI / AI Services endpoint (passwordless auth via managed identity).
AZURE_OPENAI_ENDPOINT=https://<your-aoai-resource>.openai.azure.com/

# Azure OpenAI API version.
OPENAI_API_VERSION=2024-10-21

# Optional: override which agent network to serve (key in registries/manifest.hocon).
# NEURO_SAN_AGENT_NAME=hello_world

# Local-only: use an API key instead of passwordless auth (the LLM policy will
# defer to key-based auth when this is set).
# AZURE_OPENAI_API_KEY=<key>

# Local-only: enable tracing during local runs.
# APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=...
